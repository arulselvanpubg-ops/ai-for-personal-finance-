# Streamlit Secrets Configuration
# Add these secrets in Streamlit Cloud dashboard:
# Settings → Secrets → Add secret

# MongoDB Configuration (Required)
MONGODB_URI = "mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/"
MONGODB_DB_NAME = "finsight"

# Google AI API (Required)
GOOGLE_API_KEY = "your-google-api-key-here"

# NVIDIA NIM API (Required)
NVIDIA_API_KEY = "your-nvidia-api-key-here"
NVIDIA_BASE_URL = "https://integrate.api.nvidia.com/v1"
NVIDIA_MODEL = "meta/llama-3.1-70b-instruct"

# Hugging Face API (Optional - will use keyword fallback if not provided)
HF_API_KEY = "your-huggingface-api-key-here"
HF_CATEGORIZER_MODEL = "facebook/bart-large-mnli"

# Gemini Model (Optional)
GEMINI_MODEL = "gemini-1.5-flash"

# App Configuration
APP_SECRET_KEY = "your-secret-key-here"
SESSION_TIMEOUT_MINUTES = 15
