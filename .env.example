# NVIDIA NIM
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.1-70b-instruct

# Hugging Face
HF_API_KEY=your_huggingface_api_key_here
HF_CATEGORIZER_MODEL=facebook/bart-large-mnli
HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# Statement import categorization: hybrid (default, deduped + keyword first), keyword_only, api_per_row
IMPORT_CATEGORIZE_MODE=hybrid

# Google AI Studio
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# App Config
APP_SECRET_KEY=your-random-secret
DB_BACKEND=auto
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/
MONGODB_DB_NAME=finsight
SQLITE_DB_PATH=data/finsight.db
SESSION_TIMEOUT_MINUTES=15
